# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — leave blank to skip those sources
EVENTBRITE_TOKEN=your_eventbrite_oauth_token_here
MEETUP_TOKEN=your_meetup_oauth_token_here

# Database (defaults to SQLite in project root)
DATABASE_URL=sqlite:///./events.db

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
